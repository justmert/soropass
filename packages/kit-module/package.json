{
  "name": "@stellar-passkey/wallets-kit-module",
  "version": "0.0.0",
  "private": true,
  "description": "PasskeyModule for @creit.tech/stellar-wallets-kit — a thin adapter over @stellar-passkey/core. Staged here; upstreamed via PR (S27), not published as a parallel package.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint src"
  },
  "dependencies": {
    "@stellar-passkey/core": "workspace:^"
  },
  "devDependencies": {
    "@stellar/stellar-sdk": "^15.1.0",
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  }
}
