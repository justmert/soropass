---
// Live, client-side WebAuthn feature detection ("your device" panel) — reuses
// the SDK's detectCapabilities() so the matrix page shows the reader's own browser.
---

<div class="device-panel not-content" id="pk-device-panel">
  <p>Probing your device…</p>
</div>

<script>
  import { detectCapabilities } from '../../src/featureDetect';

  const el = document.getElementById('pk-device-panel');
  if (el) {
    detectCapabilities()
      .then((r) => {
        const caps = r.clientCapabilities
          ? `<li><code>getClientCapabilities()</code>: <code>${JSON.stringify(r.clientCapabilities)}</code></li>`
          : '';
        el.innerHTML = `<ul>
          <li>WebAuthn available: <strong>${String(r.webauthnAvailable)}</strong></li>
          <li>Platform authenticator (<code>isUVPAA</code>): <strong>${String(r.isUvpaa)}</strong></li>
          <li>Conditional UI: <strong>${String(r.conditionalMediation)}</strong></li>
          ${caps}
          <li>User agent: <code>${r.userAgent}</code></li>
        </ul>`;
      })
      .catch(() => {
        el.textContent = 'Feature detection is unavailable in this context.';
      });
  }
</script>

<style>
  .device-panel ul {
    list-style: none;
    padding: 0;
  }
  .device-panel li {
    padding: 0.15rem 0;
  }
</style>
