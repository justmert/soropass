{
  "name": "@stellar-passkey/matrix",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Astro Starlight docs site + living compatibility-matrix.",
  "scripts": {
    "matrix:pull": "tsx scripts/pull-bcd.ts",
    "matrix:ci": "tsx ci/run-matrix-ci.ts",
    "matrix:build": "tsx scripts/build-matrix.ts",
    "matrix:diff": "tsx scripts/diff-matrix.ts",
    "matrix:refresh": "pnpm matrix:pull && pnpm matrix:build && pnpm matrix:diff",
    "build": "astro build",
    "dev": "astro dev",
    "preview": "astro preview",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@astrojs/starlight": "^0.39.2",
    "@stellar-passkey/core": "workspace:^",
    "astro": "^6.4.2",
    "starlight-typedoc": "^0.23.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@mdn/browser-compat-data": "^8.0.0",
    "@playwright/test": "^1.60.0",
    "@types/node": "^22.0.0",
    "astro-mermaid": "^2.0.1",
    "mermaid": "^11.15.0",
    "tsx": "^4.22.3",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.11.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  }
}
